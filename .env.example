# Facebook Configuration
# Get these from Facebook Developer Console (developers.facebook.com)

# Page Access Token (long-lived token from Facebook Developer Console)
FB_PAGE_ACCESS_TOKEN=

# Your Facebook Page ID
FB_PAGE_ID=

# Verify Token (create your own random string for webhook verification)
FB_VERIFY_TOKEN=your_random_verify_token_here

# ============================================
# How to setup Facebook Messenger:
# ============================================
#
# 1. Go to developers.facebook.com and create an app
# 2. Add "Messenger" product to your app
# 3. Select your Facebook Page
# 4. Get the Page Access Token
# 5. Fill in the values above
# 6. Configure webhook URL: https://your-domain.com/webhook
# 7. Use the same verify token you set above
#
# Note: Your domain must have HTTPS (use ngrok for local testing)

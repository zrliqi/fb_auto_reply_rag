PORT=5000
LOG_LEVEL=INFO

# Messenger credentials
FB_VERIFY_TOKEN=change_me_verify_token
FB_PAGE_ACCESS_TOKEN=change_me_page_access_token
FB_APP_SECRET=change_me_app_secret_optional
FB_GRAPH_API_VERSION=v20.0

# Runtime behavior
WEBHOOK_TIMEOUT_SECONDS=10
DEFAULT_REPLY=Thanks for your message. We will get back to you shortly.
SQLITE_DB_PATH=data/conversations.db

# OpenAI-compatible AI engine
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=change_me_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=20

# Model routing and context window
USE_FALLBACK=true
PRIMARY_MODEL=openai
FALLBACK_MODEL=llama
CONTEXT_HISTORY_LIMIT=12
OPENAI_FAILURE_THRESHOLD=3
OPENAI_COOLDOWN_SECONDS=300

# Local LLaMA/Ollama fallback
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
LLAMA_REQUEST_TIMEOUT_SECONDS=45
LLAMA_STREAMING=false

# Optional local_fun_bot continuity fallback (used when both model providers fail)
LOCAL_FUN_BOT_URL=
LOCAL_API_KEY=
USE_LOCAL_FUN_BOT_ON_RULE_BASED=true

# RAG placeholder knowledge source
KB_FILE=data/knowledge_base.txt
RAG_TOP_K=3
